# Web application environment variables
# Copy to .env and fill in real values for local development.
# Never commit .env to version control.
# In CI/CD, these values are sourced from GitHub Actions variables (vars.*) and secrets (secrets.*).
#
# Variable reference (see docs/engineering/configuration-and-secrets.md for full catalogue):
#
# Name               | Source          | App   | Environments    | Rotate? | Description
# -------------------|-----------------|-------|-----------------|---------|---------------------------------------------
# NODE_ENV           | vars.NODE_ENV   | web   | dev/stg/prd     | No      | Runtime environment label
# PORT               | vars.WEB_PORT   | web   | dev/stg/prd     | No      | Port the web server listens on
# API_URL            | vars.API_URL    | web   | dev/stg/prd     | No      | Base URL of the backend API
# APP_URL            | vars.APP_URL    | web   | dev/stg/prd     | No      | Public base URL of this web app

NODE_ENV=development
PORT=3000
API_URL=http://localhost:3001
APP_URL=http://localhost:3000
