# API application environment variables
# Copy to .env and fill in real values for local development.
# Never commit .env to version control.
# In CI/CD, these values are sourced from GitHub Actions variables (vars.*) and secrets (secrets.*).
#
# Variable reference (see docs/engineering/configuration-and-secrets.md for full catalogue):
#
# Name               | Source          | App   | Environments    | Rotate? | Description
# -------------------|-----------------|-------|-----------------|---------|---------------------------------------------
# NODE_ENV           | vars.NODE_ENV   | api   | dev/stg/prd     | No      | Runtime environment label
# PORT               | vars.API_PORT   | api   | dev/stg/prd     | No      | Port the API server listens on
# DATABASE_URL       | secrets.DATABASE_URL | api | dev/stg/prd  | Yes     | Full connection string including credentials
# JWT_SECRET         | secrets.JWT_SECRET   | api | dev/stg/prd  | Yes     | Secret used to sign and verify JWTs
# JWT_EXPIRES_IN     | vars.JWT_EXPIRES_IN  | api | dev/stg/prd  | No      | JWT expiry duration (e.g. 1h, 7d)
# CORS_ORIGIN        | vars.CORS_ORIGIN     | api | dev/stg/prd  | No      | Allowed CORS origin(s), comma-separated
# LOG_LEVEL          | vars.LOG_LEVEL       | api | dev/stg/prd  | No      | Logging verbosity (debug/info/warn/error)

NODE_ENV=development
PORT=3001
DATABASE_URL=postgres://user:password@localhost:5432/appdb
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=1h
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=debug
