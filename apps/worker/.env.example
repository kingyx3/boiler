# Worker application environment variables
# Copy to .env and fill in real values for local development.
# Never commit .env to version control.
# In CI/CD, these values are sourced from GitHub Actions variables (vars.*) and secrets (secrets.*).
#
# Variable reference (see docs/engineering/configuration-and-secrets.md for full catalogue):
#
# Name               | Source              | App    | Environments    | Rotate? | Description
# -------------------|---------------------|--------|-----------------|---------|---------------------------------------------
# NODE_ENV           | vars.NODE_ENV       | worker | dev/stg/prd     | No      | Runtime environment label
# DATABASE_URL       | secrets.DATABASE_URL | worker | dev/stg/prd   | Yes     | Full connection string including credentials
# REDIS_URL          | secrets.REDIS_URL   | worker | dev/stg/prd     | Yes     | Redis connection string for job queue
# WORKER_CONCURRENCY | vars.WORKER_CONCURRENCY | worker | dev/stg/prd | No      | Number of concurrent jobs per worker instance
# LOG_LEVEL          | vars.LOG_LEVEL      | worker | dev/stg/prd     | No      | Logging verbosity (debug/info/warn/error)

NODE_ENV=development
DATABASE_URL=postgres://user:password@localhost:5432/appdb
REDIS_URL=redis://localhost:6379
WORKER_CONCURRENCY=2
LOG_LEVEL=debug
